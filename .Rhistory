nrow = 1,
widths = c(1,0.7),
labels = c("A", "B"),  # Adds labels to plots
label.x = 0,        # Adjust horizontal position of labels
label.y = 1,        # Adjust vertical position of labels
# vjust = 1,
# hjust = -1,
font.label = list(size = 14, face = "bold")
)
ggsave("./fig/f4.png", f4, width = 12, height = 12)
