scale_color_manual(
name = "",
values = c("Early phase" = "#5D6D7E", "Late phase" = "red")
) +
theme_minimal() +
labs(title = "Project phase", fill = "", size = "", color = "") +
coord_sf(crs = st_crs(2163), xlim = c(-2500000, 2500000),
ylim = c(-2300000,730000), expand = FALSE, datum = NA) +
theme_publication()
